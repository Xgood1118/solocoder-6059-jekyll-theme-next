---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="utf-8"?>
<search>
  {% assign sorted_posts = site.posts | sort: 'last_modified' | reverse %}
  {% for post in sorted_posts %}
    <entry>
      <title><![CDATA[{{ post.title | strip_html }}]]></title>
      <url>{{ post.url | relative_url }}</url>
      <content type="text"><![CDATA[{{ post.content | strip_html | strip_newlines }}]]></content>
      <categories>
        {% for category in post.categories %}
          <category> {{ category | strip_html | xml_escape }} </category>
        {% endfor %}
      </categories>
      <tags>
        {% for tag in post.tags %}
          <tag> {{ tag | strip_html | xml_escape }} </tag>
        {% endfor %}
      </tags>
      {% assign post_modified = post.last_modified | default: post.date %}
      <last_modified>{{ post_modified | date_to_xmlschema }}</last_modified>
    </entry>
  {% endfor %}
</search>
